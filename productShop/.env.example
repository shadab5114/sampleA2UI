# ── LLM Provider ────────────────────────────────────────────────────────────
# Switch between 'openai' and 'anthropic' — only the active provider's key is required.
LLM_PROVIDER=openai

# ── API Keys (add whichever you have) ───────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Model override (optional) ────────────────────────────────────────────────
# Default per provider: openai → gpt-4o, anthropic → claude-sonnet-4-6
A2UI_MODEL=

# ── Catalog source (MCP Tooling) ─────────────────────────────────────────────
# 'static' = bundled mui.catalog.json (default).
# 'mcp'    = fetch live from the standalone catalog MCP server.
#            Start it first:  bun run mcp-server
CATALOG_PROVIDER=static
MCP_URL=http://localhost:3100/mcp
